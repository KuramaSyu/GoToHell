#!/usr/bin/env python3
from datetime import datetime
import os
import shutil
import subprocess
import sys
from pathlib import Path

CYAN = "\033[96m"
GREEN = "\033[92m"
RED = "\033[91m"
RESET = "\033[0m"

BRANCH = "dev"
THEMES_REL = Path("src/frontend/src/theme/themes.json")
BACKUP_DATE = datetime.now().strftime("%Y%m%d-%H%M%S")
THEMES_BACKUP = Path(f"/tmp/gotohell-themes-{BACKUP_DATE}.json.backup")


def print_stage(stage: str) -> None:
    print(f"{CYAN}[+] {stage}{RESET}")


def print_info(info: str) -> None:
    print(f"{GREEN}[*] {info}{RESET}")


def print_error(error: str) -> None:
    print(f"{RED}[!] {error}{RESET}")


def run(cmd: list[str], cwd: Path | None = None) -> None:
    subprocess.run(cmd, check=True, cwd=str(cwd) if cwd else None)


def detect_repo_root() -> Path:
    try:
        output = subprocess.check_output(["git", "rev-parse", "--show-toplevel"], text=True)
        return Path(output.strip()).resolve()
    except subprocess.CalledProcessError as exc:
        raise SystemExit("This script must be run inside the GoToHell git repository.") from exc


def ensure_server_files(repo_root: Path) -> tuple[Path, Path]:
    env_file = (repo_root / ".." / ".env").resolve()
    compose_file = (repo_root / ".." / "docker-compose.yaml").resolve()

    if not env_file.is_file():
        raise SystemExit(f"Missing server-local env file: {env_file}")
    if not compose_file.is_file():
        raise SystemExit(f"Missing server-local compose file: {compose_file}")

    return env_file, compose_file


def backup_themes(repo_root: Path) -> None:
    themes_path = repo_root / THEMES_REL
    if themes_path.is_file():
        shutil.copy2(themes_path, THEMES_BACKUP)
        print_info(f"Backed up {themes_path} -> {THEMES_BACKUP}")
    else:
        print_info(f"No existing {themes_path} found to back up")


def restore_themes(repo_root: Path) -> None:
    if not THEMES_BACKUP.is_file():
        return

    themes_path = repo_root / THEMES_REL
    themes_path.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(THEMES_BACKUP, themes_path)
    THEMES_BACKUP.unlink(missing_ok=True)
    print_info(f"Restored {themes_path} from backup")


def relink_env(repo_root: Path, env_file: Path) -> None:
    target = repo_root / ".env"
    if target.exists() or target.is_symlink():
        target.unlink()

    try:
        target.symlink_to(env_file)
        print_info(f"Linked {target} -> {env_file}")
    except OSError:
        shutil.copy2(env_file, target)
        print_info(f"Symlink failed, copied env file to {target}")


def main() -> None:
    repo_root = detect_repo_root()
    env_file, compose_file = ensure_server_files(repo_root)

    print_stage("Stage 1: Back up themes.json")
    backup_themes(repo_root)

    print_stage("Stage 2: Update repository to origin/dev")
    run(["git", "fetch", "origin", BRANCH], cwd=repo_root)
    run(["git", "reset", "--hard", f"origin/{BRANCH}"], cwd=repo_root)

    print_stage("Stage 3: Restore themes.json")
    restore_themes(repo_root)

    print_stage("Stage 4: Copy docker-compose.yaml from parent")
    shutil.copy2(compose_file, repo_root / "docker-compose.yaml")
    print_info("docker-compose.yaml copied into repository")

    print_stage("Stage 5: Configure env and restart containers")
    relink_env(repo_root, env_file)
    run(["docker", "compose", "--env-file", str(env_file), "down"], cwd=repo_root)
    run(["docker", "compose", "--env-file", str(env_file), "up", "--build", "-d"], cwd=repo_root)
    print_info("Deploy complete")


if __name__ == "__main__":
    try:
        main()
    except subprocess.CalledProcessError as exc:
        print_error(f"Command failed: {exc}")
        sys.exit(1)
    except Exception as exc:
        print_error(str(exc))
        sys.exit(1)